{
  "rewrites": [
    {
      "source": "/:path(template|creator|collections|blog)/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|WhatsApp|Twitterbot|Slackbot|TelegramBot|Discordbot|LinkedInBot|Applebot|Pinterest|redditbot|Embedly|SkypeUriPreview|vkShare|W3C_Validator|Iframely|GoogleBot|bingbot|DuckDuckBot|Baiduspider|YandexBot|SocialFlow|Mastodon|Snapchat|Nuzzel|Bitrix|XING-contenttabreceiver|Google-InspectionTool|MetaInspector|Yeti|BingPreview).*"
        }
      ],
      "destination": "/api/og?path=/:path/:slug"
    },
    {
      "source": "/community/category/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|WhatsApp|Twitterbot|Slackbot|TelegramBot|Discordbot|LinkedInBot|Applebot|Pinterest|redditbot|Embedly|SkypeUriPreview|vkShare|W3C_Validator|Iframely|GoogleBot|bingbot|DuckDuckBot|Baiduspider|YandexBot|SocialFlow|Mastodon|Snapchat|Nuzzel|Bitrix|XING-contenttabreceiver|Google-InspectionTool|MetaInspector|Yeti|BingPreview).*"
        }
      ],
      "destination": "/api/og?path=/community/category/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
